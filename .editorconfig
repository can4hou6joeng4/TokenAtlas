# EditorConfig — https://editorconfig.org
# Indentation matches the project's SwiftLint configuration (4-space indent).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# YAML and JSON conventionally use 2-space indentation
# (matches .github/workflows/*.yml and tooling JSON in this repo).
[*.{yml,yaml,json}]
indent_size = 2

# Markdown: trailing whitespace can be a meaningful hard line break.
[*.md]
trim_trailing_whitespace = false

# Makefiles require literal tabs.
[{Makefile,*.mk}]
indent_style = tab
