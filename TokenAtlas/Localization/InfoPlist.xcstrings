    "NSAppleEventsUsageDescription" : {
      "comment" : "Privacy - AppleEvents Sending Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notch Island media controls may use Apple Events for local music apps when the media module is enabled."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "启用媒体模块后，Notch Island 媒体控制可能会使用 Apple Events 控制本机音乐应用。"
          }
        }
      }
    },
